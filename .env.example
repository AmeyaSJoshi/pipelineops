# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./pipelineops.db
ALLOW_WRITES=false

# ── GMI MaaS / AgentBox ──────────────────────────────────────────────────────
# TODO: Join GMI Cloud Discord for credits → http://discord.gg/mbYhCJSbF6
# TODO: Request hackathon credits, then fill these in:
GMI_MAAS_BASE_URL=
GMI_MAAS_API_KEY=
GMI_MODELS=
GMI_SELECTED_MODEL=
GMI_AGENTBOX_DEPLOYMENT_MODE=
GMI_AGENTBOX_MARKETPLACE_CATEGORY=Data & Analytics
GMI_AGENTBOX_LISTING_STATUS=Draft

# ── Local LLM fallback (optional) ────────────────────────────────────────────
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=

# ── Google Sheets export (optional) ──────────────────────────────────────────
# Paste the contents of your service account JSON (single-line escaped):
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_API_BASE_URL=http://localhost:8080
