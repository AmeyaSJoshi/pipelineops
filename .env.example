# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./pipelineops.db
# For production: DATABASE_URL=postgresql://user:pass@host:5432/pipelineops
ALLOW_WRITES=false

# ── Security ──────────────────────────────────────────────────────────────────
# Required: generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=
SECRET_KEY=

# ── GMI MaaS / AgentBox ──────────────────────────────────────────────────────
# Join GMI Cloud Discord for credits: https://discord.gg/mbYhCJSbF6
GMI_MAAS_BASE_URL=
GMI_MAAS_API_KEY=
GMI_MODELS=
GMI_SELECTED_MODEL=
GMI_AGENTBOX_DEPLOYMENT_MODE=
GMI_AGENTBOX_MARKETPLACE_CATEGORY=Data & Analytics
GMI_AGENTBOX_LISTING_STATUS=Draft

# ── Local LLM fallback (optional) ────────────────────────────────────────────
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=

# ── Greenhouse Harvest API ────────────────────────────────────────────────────
# Obtain from: Greenhouse admin > Configure > Dev Center > API Credential Management
# Auth: HTTP Basic with this key as username, empty password
GREENHOUSE_API_KEY=

# ── Lever Data API ────────────────────────────────────────────────────────────
# Obtain from: Lever admin > Settings > Integrations & API > API Credentials
# Auth: HTTP Basic with this key as username, empty password
LEVER_API_KEY=

# ── Bullhorn REST API ─────────────────────────────────────────────────────────
# Requires corporate Bullhorn subscription and OAuth app registration.
# BULLHORN_PASSWORD is used only for initial OAuth token exchange and is NOT persisted.
BULLHORN_CLIENT_ID=
BULLHORN_CLIENT_SECRET=
BULLHORN_USERNAME=
BULLHORN_PASSWORD=

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Single-line JSON contents of a service account key file.
# Steps: Create service account → download JSON key → share spreadsheet with service account email (Editor).
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Blocked sources (Indeed / CareerBuilder / Monster / Dice) ─────────────────
# No env vars needed — these are blocked-state connectors with no official public API.
# Users can export CSVs from these platforms and upload via /sync/file.
# See CONNECTOR_AUDIT.md for details and path-to-unblock for each source.

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_API_BASE_URL=http://localhost:8080
